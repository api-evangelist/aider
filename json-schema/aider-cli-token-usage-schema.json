{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/aider/refs/heads/main/json-schema/aider-cli-token-usage-schema.json",
  "title": "TokenUsage",
  "description": "TokenUsage schema from Aider CLI",
  "type": "object",
  "properties": {
    "chat_history_tokens": {
