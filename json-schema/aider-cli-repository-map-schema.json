{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/aider/refs/heads/main/json-schema/aider-cli-repository-map-schema.json",
  "title": "RepositoryMap",
  "description": "RepositoryMap schema from Aider CLI",
  "type": "object",
  "properties": {
    "token_budget": {
      "type": "integer",
      "example": 4096
    },
    "symbols": {
      "type": "array",
      "description": "Tree-sitter-extracted symbol summaries per file.",
      "items": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "example": "src/main.py"
          },
          "symbols": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "class Cache"
            },
            "example": [
              "class Cache",
              "def get(self, key)"
            ]
          }
        }
      }
    }
  }
}